APP_NAME=MySocialVSL
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Single-origin : front + API + pages publiques servis par Laravel sur CE domaine.
# APP_URL.host sert aussi à distinguer le domaine principal des custom domains.
APP_URL=https://mysocialvsl.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@mysocialvsl.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 — stockage vidéos & images (egress gratuit)
# Dashboard Cloudflare → R2 → ton bucket → Settings → API tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mysocialvsl-uploads
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.mysocialvsl.com

VITE_APP_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
# Pack add-ons — créer ces 2 prices dans Stripe (recurring, per_unit, 9€)
STRIPE_PRICE_EXTRA_PAGES=
STRIPE_PRICE_EXTRA_LINKS=

FRONTEND_URL=https://mysocialvsl.com

# Sentry — monitoring d'erreurs prod. DSN depuis sentry.io (Settings → Client Keys).
# Laisser VIDE en local pour ne rien envoyer. Tracing perf off par défaut (quota gratuit).
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"

# Single-origin : NE PAS définir VITE_API_URL au build → axios utilise /api en
# relatif (même domaine, pas de CORS). Ne le remplir que si l'API est séparée.
# VITE_API_URL=
